# Portable default: keep TensorFlow on CPU so zipped copies work on most PCs.
# Set FORCE_CPU_INFERENCE=0 only if that PC has a working NVIDIA CUDA setup.
FORCE_CPU_INFERENCE=1

# Neural detector weights (pick one):
# MODEL_WEIGHTS_PATH=/absolute/path/to/best_model_effatt.h5
# Default file: models/best_model_effatt.h5
# MODEL_REPO_ID=your-org/your-model-repo
# MODEL_FILENAME=best_model_effatt.h5

# Optional: browser → FastAPI base URL. In `next dev`, defaults use 127.0.0.1 on desktop;
# on another device use http://YOUR_PC_IP:3000 — same-host :8000 is chosen automatically.
# Override if needed (e.g. API on another machine):
# NEXT_PUBLIC_API_URL=http://192.168.1.10:8000

# Where Next.js proxies /api/* in dev/build (FastAPI). Default: http://127.0.0.1:8000
# API_BACKEND_URL=http://127.0.0.1:8000

# ----------------------------------------------------------------------------
# Agentic CrewAI investigation (POST /api/analyze)
# ----------------------------------------------------------------------------
# OpenAI key powers the CrewAI manager, fusion, and report-writer agents.
# REQUIRED: when missing, /api/analyze returns 503.
# Put your real key in a file named `.env` in the project root — see README. Never commit `.env`.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# CrewAI: disable interactive tracing prompts in logs (recommended for servers/containers).
# CREWAI_TRACING_ENABLED=false

# Sightengine credentials enable the external AI-image / deepfake / quality
# verification agent. Leave unset to skip that agent gracefully.
# SIGHTENGINE_API_USER=
# SIGHTENGINE_API_SECRET=

# Per-tool wall-clock budget and total investigation budget (seconds).
# AGENTIC_TOOL_TIMEOUT_SECONDS=20
# AGENTIC_TIMEOUT_SECONDS=60

# Cap on concurrent crew kickoffs per worker process. Keeps OpenAI bursts
# and TF memory bounded. Default: 1.
# AGENTIC_MAX_CONCURRENT_CREWS=1

# Set to 1/true to include the raw Sightengine payload in the response.
# AGENTIC_INCLUDE_RAW=false

# Optional explicit binary paths (otherwise discovered via $PATH).
# Ubuntu: after `bash scripts/install-analysis-deps-ubuntu.sh`, defaults usually work.
# EXIFTOOL_PATH=/usr/bin/exiftool
# TESSERACT_PATH=/usr/bin/tesseract

# Fusion weights (positive floats; missing signals are dropped automatically).
# Defaults mirror AgenticSettings in api/agentic/context.py — tune per deployment.
# AGENTIC_W_LOCAL=0.45
# AGENTIC_W_SIGHTENGINE_GENAI=0.25
# AGENTIC_W_SIGHTENGINE_DEEPFAKE=0.25
# AGENTIC_W_SIGHTENGINE_OCR=0.15   # Sightengine OCR text-risk score (API side-channel)
# AGENTIC_W_VISUAL=0.10
# AGENTIC_W_METADATA=0.08
# AGENTIC_W_FACE=0.25
# AGENTIC_W_OCR=0.07               # Local Tesseract string-pattern score (after Sightengine merge if needed)
# AGENTIC_W_IMAGE_QUALITY=0.12     # Low resolution, compression, re-encoding heuristics

# Blend between fused "core" detectors (local + Sightengine) vs auxiliary heuristics
# (metadata, visual forensics, OCR string patterns). 1.0 = core only.
# AGENTIC_FUSION_CORE_BLEND=0.85
